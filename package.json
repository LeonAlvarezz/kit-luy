{
  "name": "kit-luy",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:push": "bunx drizzle-kit push",
    "db:gen": "bunx drizzle-kit generate",
    "db:hard-reset": "rm -rf .wrangler/state/v3/d1",
    "db:migrate": "bun --no-env-file run src/lib/db/migrate.ts",
    "db:reset": "bun --no-env-file run src/lib/db/reset.ts",
    "typesafe-i18n": "typesafe-i18n"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "telegraf": "^4.16.3",
    "typesafe-i18n": "^5.27.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/bun": "^1.3.14",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.4.0"
  }
}
